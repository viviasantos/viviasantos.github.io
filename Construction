<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Viviane Santos — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;scroll-behavior:smooth}
body{
  font-family:'DM Sans',sans-serif;
  background:#0f1117;
  color:#e2e8f0;
  min-height:100vh;
  line-height:1.6;
}

/* ── NAV ── */
nav{
  display:flex;align-items:center;justify-content:space-between;
  padding:1.25rem 2.5rem;
  border-bottom:1px solid rgba(255,255,255,.08);
  position:sticky;top:0;background:#0f1117;z-index:100;
}
.nav-logo{font-size:15px;font-weight:600;color:#fff;text-decoration:none;letter-spacing:.01em}
.nav-links{display:flex;align-items:center;gap:1.5rem}
.nav-links a{
  font-size:13px;color:rgba(255,255,255,.5);text-decoration:none;
  transition:color .2s;
}
.nav-links a:hover{color:#fff}
.nav-icon{
  display:flex;align-items:center;justify-content:center;
  width:32px;height:32px;border-radius:6px;
  border:1px solid rgba(255,255,255,.12);
  color:rgba(255,255,255,.5);text-decoration:none;font-size:14px;
  transition:border-color .2s,color .2s;
}
.nav-icon:hover{border-color:rgba(255,255,255,.3);color:#fff}

/* ── HERO ── */
.hero{
  max-width:760px;margin:0 auto;
  padding:5rem 2rem 3rem;
  text-align:center;
}
.hero h1{font-size:2.4rem;font-weight:600;color:#fff;line-height:1.2;margin-bottom:1rem}
.hero p{font-size:14px;color:rgba(255,255,255,.45);line-height:1.8;max-width:560px;margin:0 auto 2rem}
.hero-tags{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:3rem}
.hero-tag{
  font-size:11px;color:rgba(255,255,255,.45);
  border:1px solid rgba(255,255,255,.12);
  border-radius:4px;padding:4px 10px;
}

/* ── SECTION DIVIDER ── */
.section-label{
  max-width:760px;margin:0 auto;
  padding:0 2rem 1.25rem;
  font-size:11px;font-weight:600;letter-spacing:.1em;
  text-transform:uppercase;color:rgba(255,255,255,.25);
  border-bottom:1px solid rgba(255,255,255,.07);
  margin-bottom:2.5rem;
}

/* ── PROJECT CARD ── */
.projects{max-width:760px;margin:0 auto;padding:0 2rem;display:flex;flex-direction:column;gap:3.5rem}

.project-meta{display:flex;align-items:center;gap:8px;margin-bottom:.75rem;flex-wrap:wrap}
.project-date{font-size:12px;color:rgba(255,255,255,.28)}
.project-tag{
  font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;
  border:1px solid rgba(255,255,255,.14);border-radius:4px;
  padding:2px 8px;color:rgba(255,255,255,.45);
}
.project h2{font-size:1.25rem;font-weight:600;color:#fff;margin-bottom:.75rem;line-height:1.35}
.project-intro{font-size:14px;color:rgba(255,255,255,.55);line-height:1.75;margin-bottom:1.5rem;max-width:640px}

/* metrics */
.metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:1.25rem}
.metric{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.09);
  border-radius:8px;padding:.9rem 1rem;
}
.metric-label{font-size:11px;letter-spacing:.05em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:4px}
.metric-value{font-size:1.3rem;font-weight:600;color:#fff}

/* detail grid */
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1.5rem}
.card{
  background:rgba(255,255,255,.03);
  border:1px solid rgba(255,255,255,.09);
  border-radius:10px;padding:1.1rem 1.2rem;
}
.card-title{
  font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;
  color:rgba(255,255,255,.3);margin-bottom:.85rem;
}
.right-col{display:flex;flex-direction:column;gap:10px}

/* steps */
.steps{display:flex;flex-direction:column;gap:10px}
.step{display:flex;gap:10px;align-items:flex-start}
.step-n{
  width:20px;height:20px;flex-shrink:0;border-radius:50%;
  background:rgba(99,179,237,.15);border:1px solid rgba(99,179,237,.3);
  color:#90cdf4;font-size:10px;font-weight:700;
  display:flex;align-items:center;justify-content:center;margin-top:1px;
}
.step-t{font-size:13px;color:rgba(255,255,255,.52);line-height:1.55}

/* challenge */
.challenge-text{font-size:13px;color:rgba(255,255,255,.52);line-height:1.65}

/* tech pills */
.tech-pills{display:flex;flex-wrap:wrap;gap:6px}
.tech-pill{
  font-size:11px;color:rgba(255,255,255,.45);
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.1);
  border-radius:4px;padding:3px 8px;
}

/* repo button */
.repo-btn{
  display:inline-flex;align-items:center;gap:6px;
  font-size:13px;font-weight:500;
  border:1px solid rgba(255,255,255,.18);
  border-radius:6px;padding:8px 18px;
  color:rgba(255,255,255,.7);text-decoration:none;
  transition:border-color .2s,color .2s,background .2s;
}
.repo-btn:hover{border-color:rgba(255,255,255,.4);color:#fff;background:rgba(255,255,255,.06)}
.repo-btn svg{width:14px;height:14px;fill:currentColor}

/* divider between projects */
.project-divider{border:none;border-top:1px solid rgba(255,255,255,.07);margin:0}

/* ── FOOTER ── */
footer{
  max-width:760px;margin:4rem auto 0;
  padding:2rem;
  border-top:1px solid rgba(255,255,255,.07);
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;
}
footer p{font-size:12px;color:rgba(255,255,255,.25)}
.footer-links{display:flex;gap:1rem}
.footer-links a{font-size:12px;color:rgba(255,255,255,.35);text-decoration:none;transition:color .2s}
.footer-links a:hover{color:#fff}

/* ── RESPONSIVE ── */
@media(max-width:600px){
  nav{padding:1rem 1.25rem}
  .hero{padding:3rem 1.25rem 2rem}
  .hero h1{font-size:1.75rem}
  .projects{padding:0 1.25rem}
  .section-label{padding:0 1.25rem 1rem}
  .metrics{grid-template-columns:1fr 1fr}
  .detail-grid{grid-template-columns:1fr}
  footer{padding:1.5rem 1.25rem}
}
</style>
</head>
